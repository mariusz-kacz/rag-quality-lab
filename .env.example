# Copy this file to .env.local for local live-service testing, then run commands as:
# raglab --env-file .env.local corpus ingest --collection rag_quality_lab --recreate
#
# Azure AI Foundry project OpenAI-compatible endpoint
# If Foundry shows a URL ending in /responses, remove that suffix here.
# When FOUNDRY_API_KEY is empty, the app uses Entra ID via DefaultAzureCredential.
FOUNDRY_OPENAI_BASE_URL=https://your-project.services.ai.azure.com/api/projects/your-project/openai/v1
FOUNDRY_API_KEY=
FOUNDRY_EMBEDDING_MODEL=text-embedding-3-small
FOUNDRY_CHAT_MODEL=gpt-4o-mini

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
RAGLAB_QDRANT_COLLECTION=rag_quality_lab
